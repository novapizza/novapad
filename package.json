{
  "name": "NovaPad",
  "version": "1.2.8",
  "description": "A lightweight, fast, and modern text editor for Windows, macOS.",
  "main": "out/main/index.js",
  "packageManager": "pnpm@9.15.0",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/build-worker.mjs && env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build && node scripts/build-worker.mjs",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "package": "[ -f .env ] && set -a && . ./.env && set +a; electron-builder --config electron-builder.cjs",
    "package:win": "[ -f .env ] && set -a && . ./.env && set +a; electron-builder --win --config electron-builder.cjs",
    "package:mac": "[ -f .env ] && set -a && . ./.env && set +a; electron-builder --mac --config electron-builder.cjs",
    "release:preflight": "[ -f .env ] && set -a && . ./.env && set +a; node scripts/release-preflight.mjs",
    "release:mac": "[ -f .env ] && set -a && . ./.env && set +a; pnpm run release:preflight -- mac && pnpm run build && GH_TOKEN=$(gh auth token) electron-builder --mac --publish always --config electron-builder.cjs",
    "release:win": "[ -f .env ] && set -a && . ./.env && set +a; pnpm run release:preflight -- win && pnpm run build && GH_TOKEN=$(gh auth token) electron-builder --win --publish always --config electron-builder.cjs",
    "release:verify": "[ -f .env ] && set -a && . ./.env && set +a; node scripts/verify-release.mjs",
    "release:all": "[ -f .env ] && set -a && . ./.env && set +a; pnpm run release:preflight -- all && pnpm run release:mac && pnpm run release:win && pnpm run release:verify",
    "test:e2e": "pnpm run build && playwright test",
    "test:e2e:headed": "pnpm run build && playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "build:worker": "node scripts/build-worker.mjs",
    "postinstall": "node node_modules/electron/install.js"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.0.20",
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "adm-zip": "^0.5.17",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chardet": "^2.0.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^5.7.2",
    "highlight.js": "^11.11.1",
    "iconv-lite": "^0.6.3",
    "jsonrepair": "^3.14.0",
    "lucide-react": "^1.7.0",
    "magika": "^1.0.0",
    "merslim": "^0.2.3",
    "monaco-editor": "^0.52.2",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.4",
    "sql-formatter": "^15.7.4",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.3"
  },
  "overrides": {
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.5",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.25.0",
    "gif-encoder-2": "^1.0.5",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.25.0",
    "@rollup/rollup-win32-x64-msvc": "^4.60.4"
  }
}
